---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#030014" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="antialiased">
    <!-- galaxy backdrop -->
    <div class="fixed inset-0 -z-10" aria-hidden="true">
      <canvas id="starfield" class="absolute inset-0 h-full w-full"></canvas>
      <div class="nebula h-[42rem] w-[42rem] -top-40 -left-40" style="background: radial-gradient(circle, rgba(124,58,237,0.55), transparent 65%);"></div>
      <div class="nebula h-[36rem] w-[36rem] top-1/3 -right-48" style="background: radial-gradient(circle, rgba(217,70,239,0.4), transparent 65%); animation-delay: -9s;"></div>
      <div class="nebula h-[38rem] w-[38rem] bottom-0 left-1/4" style="background: radial-gradient(circle, rgba(34,211,238,0.28), transparent 65%); animation-delay: -18s;"></div>
    </div>

    <slot />

    <script>
      // ---------- starfield ----------
      const canvas = document.getElementById('starfield');
      if (canvas instanceof HTMLCanvasElement) {
        const ctx = canvas.getContext('2d');
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const DPR = Math.min(window.devicePixelRatio || 1, 2);
        const COLORS = ['#ffffff', '#e0e7ff', '#c7d2fe', '#a5f3fc', '#f5d0fe'];

        let w = 0;
        let h = 0;
        let stars = [];
        let shootingStars = [];
        let mouseTarget = { x: 0, y: 0 };
        let mouse = { x: 0, y: 0 };
        let nextShootingStar = 3000;

        function resize() {
          w = window.innerWidth;
          h = window.innerHeight;
          canvas.width = w * DPR;
          canvas.height = h * DPR;
          ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
          const count = Math.min(420, Math.floor((w * h) / 3400));
          stars = Array.from({ length: count }, () => {
            const depth = Math.random(); // 0 = far, 1 = near
            return {
              x: Math.random() * w,
              y: Math.random() * h,
              depth,
              radius: 0.3 + depth * 1.3,
              color: COLORS[Math.floor(Math.random() * COLORS.length)],
              baseAlpha: 0.25 + depth * 0.55,
              twinkleSpeed: 0.4 + Math.random() * 1.6,
              twinklePhase: Math.random() * Math.PI * 2,
              driftX: (Math.random() - 0.5) * 0.014 * (0.3 + depth),
              driftY: (Math.random() - 0.5) * 0.008 * (0.3 + depth),
            };
          });
        }

        function spawnShootingStar() {
          const angle = Math.PI * (0.65 + Math.random() * 0.2); // down-left-ish
          const speed = 9 + Math.random() * 5;
          shootingStars.push({
            x: w * (0.3 + Math.random() * 0.7),
            y: h * Math.random() * 0.4,
            vx: Math.cos(angle) * speed,
            vy: Math.sin(angle) * speed,
            life: 1,
          });
        }

        function draw(t) {
          ctx.clearRect(0, 0, w, h);
          mouse.x += (mouseTarget.x - mouse.x) * 0.04;
          mouse.y += (mouseTarget.y - mouse.y) * 0.04;

          for (const s of stars) {
            if (!reduced) {
              s.x += s.driftX;
              s.y += s.driftY;
              if (s.x < -2) s.x = w + 2;
              if (s.x > w + 2) s.x = -2;
              if (s.y < -2) s.y = h + 2;
              if (s.y > h + 2) s.y = -2;
            }
            const twinkle = reduced
              ? 0
              : Math.sin(t * 0.001 * s.twinkleSpeed + s.twinklePhase) * 0.25;
            const px = s.x + mouse.x * s.depth * 22;
            const py = s.y + mouse.y * s.depth * 14;
            ctx.globalAlpha = Math.max(0.05, Math.min(1, s.baseAlpha + twinkle));
            ctx.fillStyle = s.color;
            ctx.beginPath();
            ctx.arc(px, py, s.radius, 0, Math.PI * 2);
            ctx.fill();
          }

          if (!reduced) {
            if (t > nextShootingStar) {
              spawnShootingStar();
              nextShootingStar = t + 4000 + Math.random() * 6000;
            }
            for (const m of shootingStars) {
              m.x += m.vx;
              m.y += m.vy;
              m.life -= 0.016;
              if (m.life <= 0) continue;
              const tailX = m.x - m.vx * 9;
              const tailY = m.y - m.vy * 9;
              const grad = ctx.createLinearGradient(m.x, m.y, tailX, tailY);
              grad.addColorStop(0, `rgba(226, 232, 255, ${0.9 * m.life})`);
              grad.addColorStop(1, 'rgba(226, 232, 255, 0)');
              ctx.strokeStyle = grad;
              ctx.lineWidth = 1.6;
              ctx.globalAlpha = 1;
              ctx.beginPath();
              ctx.moveTo(m.x, m.y);
              ctx.lineTo(tailX, tailY);
              ctx.stroke();
            }
            shootingStars = shootingStars.filter((m) => m.life > 0 && m.y < h + 60);
          }

          ctx.globalAlpha = 1;
          if (!reduced) requestAnimationFrame(draw);
        }

        window.addEventListener('resize', () => {
          resize();
          if (reduced) draw(0);
        });
        window.addEventListener('pointermove', (e) => {
          mouseTarget.x = e.clientX / w - 0.5;
          mouseTarget.y = e.clientY / h - 0.5;
        });

        resize();
        if (reduced) {
          draw(0);
        } else {
          requestAnimationFrame(draw);
        }
      }

      // ---------- scroll reveal ----------
      const revealEls = document.querySelectorAll('[data-reveal]');
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      revealEls.forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
